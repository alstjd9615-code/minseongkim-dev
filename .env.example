# Copy this file to .env.local and fill in your values

# API Gateway base URL (output from SAM deploy)
# Example: https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev
VITE_API_BASE_URL=

# Cognito User Pool (from SAM deploy outputs: UserPoolId and UserPoolClientId)
# Run: aws cloudformation describe-stacks --stack-name <your-stack> --query "Stacks[0].Outputs"
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
